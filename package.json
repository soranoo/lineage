{
  "name": "@soranoo/lineage",
  "description": "Follow the lineage of any value, across every file.",
  "keywords": [
    "dependency graph",
    "static analysis",
    "typescript",
    "javascript"
  ],
  "license": "GPL-3.0-only",
  "author": "soranoo",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:cov": "vitest run --coverage",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "assert-never": "^1.4.0",
    "magic-string": "^0.30.21",
    "neverthrow": "^8.2.0",
    "oxc-parser": "^0.131.0",
    "oxc-resolver": "^11.23.0",
    "vitest": "^4.1.10"
  },
  "devDependencies": {
    "@oxc-project/types": "^0.131.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^4.1.10",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.73.0",
    "tsc-alias": "^1.9.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "version": "1.0.0"
}
